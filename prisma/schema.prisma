generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  role      String   @default("member")
  notificationPrefs String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasksCreated      Task[]            @relation("TaskCreator")
  tasksAssigned     Task[]            @relation("TaskAssignee")
  taskAssignees     TaskAssignee[]
  comments          Comment[]
  timeEntries       TimeEntry[]
  ownedTeams        Team[]            @relation("TeamOwner")
  teamMemberships   TeamMember[]
  chatMessages      ChatMessage[]     @relation("ChatSender")
  chatReceived      ChatMessage[]     @relation("ChatRecipient")
  joinRequests      TeamJoinRequest[]
  foldersCreated    TeamFolder[]      @relation("TeamFolderCreator")
  filesCreated      TeamFile[]        @relation("TeamFileCreator")
  subtasksAssigned  SubTask[]         @relation("SubTaskAssignee")
  notifications     Notification[]
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String?
  url       String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  color     String?
  logo      String?
  joinCode  String?  @unique
  createdAt DateTime @default(now())

  ownerId String
  owner   User   @relation("TeamOwner", fields: [ownerId], references: [id])

  members        TeamMember[]
  invitations    TeamInvitation[]
  tasks          Task[]
  categories     Category[]
  chatMessages   ChatMessage[]
  joinRequests   TeamJoinRequest[]
  statusConfigs  TaskStatusConfig[]
  priorityConfigs TaskPriorityConfig[]
  folders        TeamFolder[]
  files          TeamFile[]
  taskTemplates  TaskTemplate[]
  webhooks       Webhook[]

  @@index([ownerId])
}

model TeamJoinRequest {
  id         String    @id
  status     String    @default("pending")
  message    String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
}

model TaskStatusConfig {
  id          String  @id
  key         String
  label       String
  color       String  @default("#9a9aa2")
  order       Int     @default(0)
  showInFocus Boolean @default(true)
  isBuiltin   Boolean @default(true)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, key])
  @@index([teamId])
}

model TaskPriorityConfig {
  id        String  @id
  key       String
  label     String
  color     String  @default("#3B82F6")
  order     Int     @default(0)
  isUrgent  Boolean @default(false)
  isBuiltin Boolean @default(false)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, key])
  @@index([teamId])
}

model TaskAssignee {
  id        String   @id
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

model TeamFolder {
  id        String   @id
  name      String
  createdAt DateTime @default(now())

  parentId String?
  parent   TeamFolder?  @relation("FolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children TeamFolder[] @relation("FolderChildren")

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("TeamFolderCreator", fields: [createdById], references: [id])

  files TeamFile[]

  @@index([teamId])
  @@index([parentId])
}

model TeamFile {
  id        String   @id
  name      String
  type      String   @default("upload")
  url       String
  mimeType  String?
  size      BigInt?
  createdAt DateTime @default(now())

  folderId String?
  folder   TeamFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("TeamFileCreator", fields: [createdById], references: [id])

  @@index([teamId])
  @@index([folderId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("ChatSender", fields: [userId], references: [id], onDelete: Cascade)

  recipientId String?
  recipient   User?   @relation("ChatRecipient", fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([recipientId])
}

model TeamMember {
  id       String   @id @default(cuid())
  role     String   @default("member")
  joinedAt DateTime @default(now())

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TeamInvitation {
  id         String    @id @default(cuid())
  email      String
  token      String    @unique @default(cuid())
  role       String    @default("member")
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  acceptedAt DateTime?

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Category {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#F97316")
  icon      String   @default("folder")
  createdAt DateTime @default(now())

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  tasks     Task[]
  templates TaskTemplate[]

  @@index([teamId])
}

model Webhook {
  id        String   @id @default(cuid())
  url       String
  secret    String?
  events    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model TaskTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("todo")
  priority    String   @default("medium")
  hourlyRate  Float?
  subtasks    Json?
  createdAt   DateTime @default(now())

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([teamId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  dueDate     DateTime?
  startDate   DateTime?
  completedAt DateTime?
  hourlyRate  Float?
  visibility  String    @default("team")
  recurring   String    @default("none")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  createdById String
  createdBy   User   @relation("TaskCreator", fields: [createdById], references: [id])

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  comments       Comment[]
  timeEntries    TimeEntry[]
  subtasks       SubTask[]
  statusHistory  TaskStatusHistory[]
  assignees      TaskAssignee[]
  blockedBy      TaskDependency[]    @relation("BlockedTask")
  blocking       TaskDependency[]    @relation("BlockerTask")

  @@index([teamId])
  @@index([status])
  @@index([assigneeId])
}

model TaskDependency {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  blockerId String
  blocker   Task   @relation("BlockerTask", fields: [blockerId], references: [id], onDelete: Cascade)

  blockedId String
  blocked   Task   @relation("BlockedTask", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

model SubTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  hourlyRate  Float?
  done        Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("SubTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  timeEntries TimeEntry[]

  @@index([assigneeId])
}

model TaskStatusHistory {
  id        String    @id @default(cuid())
  status    String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  minutes   Int?

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model TimeEntry {
  id              String    @id @default(cuid())
  startedAt       DateTime  @default(now())
  stoppedAt       DateTime?
  durationMinutes Int?
  createdAt       DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  subtaskId String?
  subtask   SubTask? @relation(fields: [subtaskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([taskId])
}
