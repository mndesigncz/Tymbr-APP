generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  role      String   @default("member")
  notificationPrefs String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasksCreated      Task[]            @relation("TaskCreator")
  tasksAssigned     Task[]            @relation("TaskAssignee")
  taskAssignees     TaskAssignee[]
  comments          Comment[]
  timeEntries       TimeEntry[]
  ownedTeams        Team[]            @relation("TeamOwner")
  teamMemberships   TeamMember[]
  chatMessages      ChatMessage[]     @relation("ChatSender")
  chatReceived      ChatMessage[]     @relation("ChatRecipient")
  joinRequests      TeamJoinRequest[]
  foldersCreated    TeamFolder[]      @relation("TeamFolderCreator")
  filesCreated      TeamFile[]        @relation("TeamFileCreator")
  subtasksAssigned  SubTask[]         @relation("SubTaskAssignee")
  notifications     Notification[]
  eventsCreated     Event[]           @relation("EventCreator")
  eventAssignments  EventAssignee[]
  contentPostsCreated  ContentPost[]  @relation("ContentPostCreator")
  contentPostsAssigned ContentPost[]  @relation("ContentPostAssignee")
  notesCreated         Note[]         @relation("NoteCreator")
  noteFolders          NoteFolder[]   @relation("NoteFolderCreator")
  noteCollaborations   NoteCollaborator[]
  shareLinks           ShareLink[]    @relation("ShareLinkCreator")
  approvalCategories   Category[]     @relation("CategoryApprover")
  approvedTasks        Task[]         @relation("TaskApprover")
  customApproverTasks  Task[]         @relation("TaskCustomApprover")
  vacations            Vacation[]     @relation("VacationUser")
  approvedVacations    Vacation[]     @relation("VacationApprover")
  clientsCreated       Client[]       @relation("ClientCreator")
  projectsCreated      Project[]      @relation("ProjectCreator")
  invoicesCreated      Invoice[]      @relation("InvoiceCreator")
  googleCalendar       GoogleCalendarAccount?
}

// A user's connected Google Calendar (OAuth). Stores the offline refresh token
// so we can mint fresh access tokens without re-consent. One per user.
model GoogleCalendarAccount {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email        String?
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  calendarId   String   @default("primary")
  syncEnabled  Boolean  @default(true)
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String?
  url       String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  color     String?
  logo      String?
  joinCode  String?  @unique
  createdAt DateTime @default(now())
  parentId  String?

  ownerId String
  owner   User   @relation("TeamOwner", fields: [ownerId], references: [id])
  parent  Team?  @relation("SubTeams", fields: [parentId], references: [id])
  subteams Team[] @relation("SubTeams")

  members        TeamMember[]
  invitations    TeamInvitation[]
  tasks          Task[]
  categories     Category[]
  chatMessages   ChatMessage[]
  joinRequests   TeamJoinRequest[]
  statusConfigs  TaskStatusConfig[]
  priorityConfigs TaskPriorityConfig[]
  folders        TeamFolder[]
  files          TeamFile[]
  taskTemplates  TaskTemplate[]
  webhooks       Webhook[]
  events         Event[]
  contentPosts   ContentPost[]
  notes          Note[]
  vacations      Vacation[]
  clients        Client[]
  projects       Project[]
  billing        TeamBilling?
  invoices       Invoice[]
  customRoles    CustomRole[]

  @@index([ownerId])
  @@index([parentId])
}

model Vacation {
  id             String   @id @default(cuid())
  type           String   @default("vacation") // vacation | sick | personal
  startDate      DateTime
  endDate        DateTime
  note           String?
  approvalStatus String   @default("pending") // pending | approved | rejected
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId String
  user   User   @relation("VacationUser", fields: [userId], references: [id], onDelete: Cascade)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  approvedById String?
  approvedBy   User?  @relation("VacationApprover", fields: [approvedById], references: [id])

  @@index([teamId])
  @@index([userId])
  @@index([startDate])
}

model Note {
  id         String   @id @default(cuid())
  title      String   @default("")
  content    String   @default("")
  color      String?
  pinned     Boolean  @default(false)
  visibility String   @default("private")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User     @relation("NoteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  // Optional user "bookmark" folder this note is filed under.
  folderId    String?
  folder      NoteFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  collaborators NoteCollaborator[]

  @@index([teamId])
  @@index([createdById])
  @@index([folderId])
}

// A user's note "bookmark" / folder for organising notes.
model NoteFolder {
  id          String   @id @default(cuid())
  name        String
  color       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String
  createdBy   User     @relation("NoteFolderCreator", fields: [createdById], references: [id], onDelete: Cascade)

  notes       Note[]

  @@index([createdById])
}

model NoteCollaborator {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  noteId String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([noteId, userId])
}

model ShareLink {
  id           String    @id @default(cuid())
  token        String    @unique
  resourceType String    // 'note' | 'task' | 'event'
  resourceId   String
  revoked      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  expiresAt    DateTime?

  teamId String?

  createdById String
  createdBy   User   @relation("ShareLinkCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([resourceType, resourceId])
  @@index([createdById])
}

model TeamJoinRequest {
  id         String    @id
  status     String    @default("pending")
  message    String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
}

model TaskStatusConfig {
  id          String  @id
  key         String
  label       String
  color       String  @default("#9a9aa2")
  order       Int     @default(0)
  showInFocus Boolean @default(true)
  isBuiltin   Boolean @default(true)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, key])
  @@index([teamId])
}

model TaskPriorityConfig {
  id        String  @id
  key       String
  label     String
  color     String  @default("#3B82F6")
  order     Int     @default(0)
  isUrgent  Boolean @default(false)
  isBuiltin Boolean @default(false)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, key])
  @@index([teamId])
}

model TaskAssignee {
  id        String   @id
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

model TeamFolder {
  id        String   @id
  name      String
  createdAt DateTime @default(now())

  parentId String?
  parent   TeamFolder?  @relation("FolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children TeamFolder[] @relation("FolderChildren")

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("TeamFolderCreator", fields: [createdById], references: [id])

  files TeamFile[]

  @@index([teamId])
  @@index([parentId])
}

model TeamFile {
  id        String   @id
  name      String
  type      String   @default("upload")
  url       String
  mimeType  String?
  size      BigInt?
  visibility String  @default("team")
  createdAt DateTime @default(now())

  folderId String?
  folder   TeamFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("TeamFileCreator", fields: [createdById], references: [id])

  @@index([teamId])
  @@index([folderId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String   @default("")
  createdAt DateTime @default(now())

  attachmentUrl  String?
  attachmentName String?
  attachmentType String? // MIME type
  attachmentSize Int?    // bytes

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("ChatSender", fields: [userId], references: [id], onDelete: Cascade)

  recipientId String?
  recipient   User?   @relation("ChatRecipient", fields: [recipientId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([recipientId])
}

model TeamMember {
  id          String   @id @default(cuid())
  role        String   @default("member")
  permissions String?
  joinedAt    DateTime @default(now())

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  customRoleId String?
  customRole   CustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

// A named permission preset a manager can define and assign to members.
model CustomRole {
  id          String   @id @default(cuid())
  name        String
  color       String?
  finance     Boolean  @default(false) // access to billing / invoices / capacity
  permissions String   @default("[]")  // JSON array of nav tab keys
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  members TeamMember[]

  @@index([teamId])
}

model TeamInvitation {
  id         String    @id @default(cuid())
  email      String
  token      String    @unique @default(cuid())
  role       String    @default("member")
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  acceptedAt DateTime?

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([email])
}

model Category {
  id              String   @id @default(cuid())
  name            String
  color           String   @default("#F97316")
  icon            String   @default("folder")
  approvalEnabled Boolean  @default(false)
  createdAt       DateTime @default(now())

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  approverId String?
  approver   User?   @relation("CategoryApprover", fields: [approverId], references: [id], onDelete: SetNull)

  tasks     Task[]
  templates TaskTemplate[]

  @@index([teamId])
  @@index([approverId])
}

model Webhook {
  id        String   @id @default(cuid())
  url       String
  secret    String?
  events    String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
}

model TaskTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      String   @default("todo")
  priority    String   @default("medium")
  hourlyRate  Float?
  subtasks    Json?
  createdAt   DateTime @default(now())

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([teamId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("medium")
  dueDate     DateTime?
  startDate   DateTime?
  completedAt DateTime?
  hourlyRate  Float?
  estimatedMinutes Int?
  expenses    Float?
  visibility  String    @default("team")
  recurring   String    @default("none")
  icon        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("TaskCreator", fields: [createdById], references: [id])

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  approvalStatus     String?
  approvedById       String?
  approvedAt         DateTime?
  approvedBy         User?     @relation("TaskApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  customApproverId   String?
  customApprover     User?     @relation("TaskCustomApprover", fields: [customApproverId], references: [id], onDelete: SetNull)

  comments       Comment[]
  timeEntries    TimeEntry[]
  subtasks       SubTask[]
  statusHistory  TaskStatusHistory[]
  assignees      TaskAssignee[]
  linkedEvents   Event[]             @relation("EventTask")
  blockedBy      TaskDependency[]    @relation("BlockedTask")
  blocking       TaskDependency[]    @relation("BlockerTask")

  @@index([teamId])
  @@index([status])
  @@index([assigneeId])
  @@index([categoryId])
  @@index([createdById])
  @@index([completedAt])
  @@index([teamId, status])
  @@index([teamId, completedAt])
  @@index([approvedById])
  @@index([customApproverId])
  @@index([projectId])
}

model Client {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  website     String?
  address     String?
  ico         String?
  dic         String?
  note        String?
  stage       String   @default("lead") // lead | negotiation | active | inactive | lost
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("ClientCreator", fields: [createdById], references: [id])

  projects Project[]
  invoices Invoice[]

  @@index([teamId])
  @@index([stage])
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("active") // active | on_hold | done | archived
  color       String?
  budget      Float?
  startDate   DateTime?
  deadline    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("ProjectCreator", fields: [createdById], references: [id])

  tasks Task[]

  @@index([teamId])
  @@index([clientId])
}

// Supplier & invoicing settings — one row per team, managed by finance roles.
model TeamBilling {
  id            String  @id @default(cuid())
  supplierName  String  @default("")
  address       String?
  ico           String?
  dic           String?
  bankAccount   String? // e.g. "123456789/0100"
  vatPayer      Boolean @default(false)
  vatRate       Float   @default(21)
  invoicePrefix String  @default("") // e.g. "2026" → 2026001
  nextNumber    Int     @default(1)
  dueDays       Int     @default(14)
  footerNote    String?
  inboundToken  String? @unique

  teamId String @unique
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Invoice {
  id             String    @id @default(cuid())
  number         String
  status         String    @default("draft") // draft | issued | paid
  issueDate      DateTime  @default(now())
  dueDate        DateTime
  paidAt         DateTime?
  subtotal       Float     @default(0)
  vatRate        Float     @default(0)
  vatAmount      Float     @default(0)
  total          Float     @default(0)
  variableSymbol String?
  note           String?
  lastReminderAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  createdById String
  createdBy   User   @relation("InvoiceCreator", fields: [createdById], references: [id])

  items InvoiceItem[]

  @@index([teamId])
  @@index([clientId])
  @@index([status])
}

model InvoiceItem {
  id          String @id @default(cuid())
  description String
  quantity    Float  @default(1)
  unit        String @default("ks") // ks | h | ...
  unitPrice   Float  @default(0)
  order       Int    @default(0)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  allDay      Boolean  @default(false)
  location    String?
  color       String?
  visibility      String    @default("personal")
  recurring       String    @default("none")
  recurringUntil  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("EventCreator", fields: [createdById], references: [id])

  taskId      String?
  task        Task?   @relation("EventTask", fields: [taskId], references: [id], onDelete: SetNull)

  assignees   EventAssignee[]

  @@index([teamId])
  @@index([createdById])
  @@index([startAt])
  @@index([teamId, startAt])
  @@index([taskId])
}

model EventAssignee {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model ContentPost {
  id          String    @id @default(cuid())
  title       String
  content     String?
  platform    String    @default("instagram")
  status      String    @default("idea")
  scheduledAt DateTime?
  publishedAt DateTime?
  link        String?
  mediaUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("ContentPostCreator", fields: [createdById], references: [id])

  assigneeId String?
  assignee   User?   @relation("ContentPostAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([teamId])
  @@index([teamId, status])
  @@index([scheduledAt])
}

model TaskDependency {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  blockerId String
  blocker   Task   @relation("BlockerTask", fields: [blockerId], references: [id], onDelete: Cascade)

  blockedId String
  blocked   Task   @relation("BlockedTask", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@index([blockerId])
}

model SubTask {
  id          String    @id @default(cuid())
  title       String
  description String?
  hourlyRate  Float?
  estimatedMinutes Int?
  done        Boolean   @default(false)
  order       Int       @default(0)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("SubTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  timeEntries TimeEntry[]

  @@index([taskId])
  @@index([assigneeId])
}

model TaskStatusHistory {
  id        String    @id @default(cuid())
  status    String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  minutes   Int?

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
}

model TimeEntry {
  id              String    @id @default(cuid())
  startedAt       DateTime  @default(now())
  stoppedAt       DateTime?
  durationMinutes Int?
  // Last time the running timer's client checked in. Used to detect a forgotten
  // timer (laptop closed / went to sleep) and offer to stop it at the last
  // confirmed activity instead of counting the idle hours.
  lastHeartbeatAt DateTime?
  createdAt       DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  subtaskId String?
  subtask   SubTask? @relation(fields: [subtaskId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([taskId])
  @@index([subtaskId])
  @@index([startedAt])
  @@index([userId, stoppedAt])
}
